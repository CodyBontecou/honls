{
  "name": "honls",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "/Users/codybontecou/.local/share/shoreman/shoreman.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx src/db/seed.ts",
    "dev:app": "next dev --turbopack",
    "dev:stop": "if [ -f .shoreman.pid ]; then kill $(cat .shoreman.pid) 2>/dev/null; rm -f .shoreman.pid; echo \"Stopped\"; else echo \"Not running\"; fi",
    "dev:log": "tail -100 ./dev.log 2>/dev/null || echo \"No dev.log yet\"",
    "dev:log:clean": "tail -100 ./dev.log 2>/dev/null | perl -pe \"s/\\e\\[[0-9;]*m(?:\\e\\[K)?//g\" || echo \"No dev.log yet\"",
    "dev:log:follow": "tail -f ./dev.log"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
